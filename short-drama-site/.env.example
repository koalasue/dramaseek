NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_PASSWORD=
CRON_SECRET=

# ReelShort、DramaBox、NetShort 官方页面元数据发现
FIRECRAWL_API_KEY=
# 自托管时改为自己的 Firecrawl 地址
FIRECRAWL_API_URL=https://api.firecrawl.dev

YOUTUBE_API_KEY=
# Google 搜索兜底：用于发现 ReelShort、DramaBox、NetShort 官方页面
SERPAPI_KEY=
AUTHORIZED_DOWNLOAD_HOSTS=
MAX_DOWNLOAD_BYTES=524288000

# 可选：独立部署 NoLanguageLeftWaiting 翻译服务后填写
NLLW_TRANSLATE_URL=
NLLW_API_KEY=

# 推荐：先用 OpenAI-compatible 翻译服务保证中文字幕可用
# OPENAI_BASE_URL 可留空，默认 https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_TRANSLATE_MODEL=gpt-4o-mini
